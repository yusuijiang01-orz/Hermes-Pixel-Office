{
  "manifest_version": 3,
  "name": "Hermes Amazon Q&A Panel",
  "version": "0.1.9",
  "description": "Show a stealth Amazon-style Hermes chat panel on Amazon pages.",
  "permissions": ["storage"],
  "host_permissions": [
    "http://127.0.0.1:8777/*",
    "http://localhost:8777/*",
    "https://amazon.com/*",
    "https://*.amazon.com/*",
    "https://amazon.co.uk/*",
    "https://*.amazon.co.uk/*",
    "https://amazon.de/*",
    "https://*.amazon.de/*",
    "https://amazon.fr/*",
    "https://*.amazon.fr/*",
    "https://amazon.it/*",
    "https://*.amazon.it/*",
    "https://amazon.es/*",
    "https://*.amazon.es/*",
    "https://amazon.nl/*",
    "https://*.amazon.nl/*",
    "https://amazon.se/*",
    "https://*.amazon.se/*",
    "https://amazon.pl/*",
    "https://*.amazon.pl/*",
    "https://amazon.com.be/*",
    "https://*.amazon.com.be/*",
    "https://amazon.ca/*",
    "https://*.amazon.ca/*",
    "https://amazon.com.mx/*",
    "https://*.amazon.com.mx/*",
    "https://amazon.com.br/*",
    "https://*.amazon.com.br/*",
    "https://amazon.co.jp/*",
    "https://*.amazon.co.jp/*",
    "https://amazon.in/*",
    "https://*.amazon.in/*",
    "https://amazon.sg/*",
    "https://*.amazon.sg/*",
    "https://amazon.com.au/*",
    "https://*.amazon.com.au/*",
    "https://amazon.ae/*",
    "https://*.amazon.ae/*",
    "https://amazon.sa/*",
    "https://*.amazon.sa/*",
    "https://amazon.eg/*",
    "https://*.amazon.eg/*",
    "https://amazon.com.tr/*",
    "https://*.amazon.com.tr/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://amazon.com/*",
        "https://*.amazon.com/*",
        "https://amazon.co.uk/*",
        "https://*.amazon.co.uk/*",
        "https://amazon.de/*",
        "https://*.amazon.de/*",
        "https://amazon.fr/*",
        "https://*.amazon.fr/*",
        "https://amazon.it/*",
        "https://*.amazon.it/*",
        "https://amazon.es/*",
        "https://*.amazon.es/*",
        "https://amazon.nl/*",
        "https://*.amazon.nl/*",
        "https://amazon.se/*",
        "https://*.amazon.se/*",
        "https://amazon.pl/*",
        "https://*.amazon.pl/*",
        "https://amazon.com.be/*",
        "https://*.amazon.com.be/*",
        "https://amazon.ca/*",
        "https://*.amazon.ca/*",
        "https://amazon.com.mx/*",
        "https://*.amazon.com.mx/*",
        "https://amazon.com.br/*",
        "https://*.amazon.com.br/*",
        "https://amazon.co.jp/*",
        "https://*.amazon.co.jp/*",
        "https://amazon.in/*",
        "https://*.amazon.in/*",
        "https://amazon.sg/*",
        "https://*.amazon.sg/*",
        "https://amazon.com.au/*",
        "https://*.amazon.com.au/*",
        "https://amazon.ae/*",
        "https://*.amazon.ae/*",
        "https://amazon.sa/*",
        "https://*.amazon.sa/*",
        "https://amazon.eg/*",
        "https://*.amazon.eg/*",
        "https://amazon.com.tr/*",
        "https://*.amazon.com.tr/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ]
}
